{
  "name": "tourism-landing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check:i18n": "tsx scripts/check-i18n-parity.ts",
    "check:i18n:hardcoded": "tsx scripts/check-hardcoded-public-chinese.ts",
    "qa:uiux:render": "python scripts/ui_ux_render_evidence.py",
    "qa:uiux:route": "tsx scripts/ui-ux-scenario-router.ts",
    "qa:uiux:scenario-coverage": "tsx scripts/ui-ux-scenario-coverage.ts",
    "qa:uiux:playbook": "tsx scripts/ui-ux-scenario-playbook.ts",
    "qa:uiux:review": "tsx scripts/ui-ux-aesthetic-review-check.ts",
    "qa:uiux:propose": "tsx scripts/ui-ux-aesthetic-proposal.ts",
    "qa:uiux:plan": "tsx scripts/ui-ux-decision-plan.ts",
    "qa:uiux:deconflict": "tsx scripts/ui-ux-deconflict-check.ts",
    "qa:uiux:audit": "tsx scripts/ui-ux-objective-audit.ts",
    "qa:uiux:handoff": "tsx scripts/ui-ux-handoff.ts",
    "qa:uiux:status": "tsx scripts/ui-ux-orchestration-status.ts",
    "prelaunch-check": "tsx scripts/prelaunch-mock-guard.ts --enforce-production && tsx scripts/prelaunch-env-check.ts",
    "prebuild": "tsx scripts/prelaunch-mock-guard.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "client:build-map": "node scripts/build-china-svg.mjs",
    "client:fetch-photos": "node scripts/fetch-landmark-photos.mjs",
    "client:export": "node scripts/export-workflow-svg.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@supabase/supabase-js": "^2.106.1",
    "@types/d3-geo": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.16.0",
    "misans-vf": "^1.0.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/env": "^16.2.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xmldom/xmldom": "^0.9.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "5.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
