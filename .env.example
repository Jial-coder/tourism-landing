# tourism-landing — environment variable example
# Copy to .env.local and fill in real values for local dev.
# DO NOT COMMIT real keys.

# Unsplash API (build-time photo fetch — scripts/fetch-landmark-photos.mjs)
# Demo tier: 50 req/h. Production tier (5000/h) needs separate application.
# Access Key only — Secret Key not needed for public photo search.
UNSPLASH_ACCESS_KEY=

# China map outline review-only flag (R-001 — see docs/known-risks.md)
# WARNING: must be false in prod, see docs/known-risks.md R-001
# Lead recommends keeping false even during review (Gemini-drawn path doesn't look like China).
# When unset / "" / anything other than the literal string "true", outline is hidden.
NEXT_PUBLIC_ENABLE_MAP_OUTLINE=false

# Supabase Free + Drizzle (Phase 0 Task 0.3)
# Get these in Supabase Dashboard → Project Settings → API / Database / General.
# Naming convention: 2026 publishable / secret (replaces legacy anon / service_role env names).
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Absolute production origin for SEO/Open Graph metadata.
# Vercel also provides VERCEL_URL automatically; SITE_URL is preferred when set.
SITE_URL=https://example.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_PLACEHOLDER
SUPABASE_SECRET_KEY=sb_secret_PLACEHOLDER
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=YOUR-REF
NEXT_PUBLIC_WHATSAPP_PHONE=8613800138000

# Lead form spam protection.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is safe for the client bundle.
# TURNSTILE_SECRET_KEY is server-only and required in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional lead notification webhook. Server-only; never prefix with NEXT_PUBLIC_.
FEISHU_WEBHOOK_URL=
