# WARNING: SUPABASE_SECRET_KEY bypasses RLS — server-only.
# Never import it from a "use client" file. Never log it. Never bake it
# into next/client bundles. Only `app/api/leads/route.ts` and `lib/db.ts`
# (server) may read it.

NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_PLACEHOLDER
SUPABASE_SECRET_KEY=sb_secret_PLACEHOLDER
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=YOUR-REF

# Absolute production origin for SEO/Open Graph metadata and generated links.
# Use the final Vercel custom domain, for example https://www.pandatravel.com.cn
SITE_URL=https://www.pandatravel.com.cn

# Lead form spam protection.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is safe for the client bundle.
# TURNSTILE_SECRET_KEY is server-only and required in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional public direct-contact shortcut. Use digits only, no "+".
NEXT_PUBLIC_WHATSAPP_PHONE=

# Optional lead notification webhook. Server-only; never prefix with NEXT_PUBLIC_.
FEISHU_WEBHOOK_URL=
