# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# package managers — repo standardizes on pnpm; do not commit npm or yarn lockfiles
package-lock.json
yarn.lock

# typescript
*.tsbuildinfo
next-env.d.ts

# project (v9 design stack)
docs/figma-cache/
docs/screenshots/
*.local.md
.idea/
.vscode/
Thumbs.db

# local QA and generation artifacts
.playwright-mcp/
hero-*.png
qa-*.png
scripts/_tmp/
.codex-run/
.superpowers/
__pycache__/
*.pyc
/qa/
docs/qa/**/*.png
docs/qa/**/*.jpg
docs/qa/**/*.jpeg
docs/qa/**/*.log
